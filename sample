main.tf


# main.tf

provider "aws" {
  region = var.region
}

resource "aws_s3_bucket" "my_bucket" {
  bucket = var.bucket_name

  acl    = var.acl

  tags = var.tags
}



# variables.tf

variable "region" {
  description = "The AWS region in which to create the S3 bucket."
  type        = string
}

variable "bucket_name" {
  description = "The name of the S3 bucket."
  type        = string
}

variable "acl" {
  description = "The access control list (ACL) to apply to the S3 bucket."
  type        = string
  default     = "private"
}

variable "tags" {
  description = "A map of tags to apply to the S3 bucket."
  type        = map(string)
  default     = {}
}



# outputs.tf

output "bucket_id" {
  description = "The ID of the created S3 bucket."
  value       = aws_s3_bucket.my_bucket.id
}



# main.tf

provider "aws" {
  region = "us-east-1"  # Replace with your desired AWS region
}

module "my_s3_bucket" {
  source      = "./s3_bucket_module"  # Replace with the actual path or URL of your module
  region      = "us-east-1"  # Replace with your desired AWS region
  bucket_name = "my-unique-bucket-name"  # Replace with your desired bucket name
  acl         = "private"  # Replace with your desired ACL
  tags        = {
    Name        = "MyS3Bucket"
    Environment = "Production"
  }
}
